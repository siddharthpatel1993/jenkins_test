//added one comment
pipeline {
    agent {
        node {
            label 'jenkinsagent'
        }      
    }
	
    options {
        buildDiscarder logRotator( 
                    daysToKeepStr: '2', 
                    numToKeepStr: '2'
            )
    }
	
    stages {
		
        stage('Create Tar file') {
            steps {
                script {
                    sh "tar -xvf /home/jenkins/${env.tagname}.tar -C /tmp/"
                    sh "echo Tag is ${env.tagname}"

                }            
            }
        }


        stage("Cleanup Workspace"){
            steps {
                cleanWs()
            }
        }
    }

    post {
     always {
            echo 'I will get displayed always'
        }

        success {
            echo 'I will get displayed if job is success'
        }

        failure {
            echo 'I will get displayed if job is failure'
        }
    }
}


