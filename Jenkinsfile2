//added one comment
pipeline {
    agent {
        node {
            label 'jenkinsagent'
        }      
    }
	
    options {
        buildDiscarder logRotator( 
                    daysToKeepStr: '2', 
                    numToKeepStr: '2'
            )
    }
	
    stages {
		
        stage("Checkout from SCM"){
            steps {
               git branch: 'master', credentialsId: 'meghachandsingh', url: 'https://gitlab.com/meghachandsingh/ipl_project'
            }
        }

        stage('Create Tar file') {
            steps {
                script {
                    sh "tar -xvf /home/jenkins/$tagname.tar -C /tmp/"
                    sh "echo Tag is $tagname"

                }            
            }
        }


        stage("Cleanup Workspace"){
            steps {
                cleanWs()
            }
        }
    }

    post {
     always {
            echo 'I will get displayed always'
        }

        success {
            echo 'I will get displayed if job is success'
        }

        failure {
            echo 'I will get displayed if job is failure'
        }
    }
}


